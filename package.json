    "@headlessui/vue": "^1.7.23",
    "@picocss/pico": "^2.1.1",
    "axios": "^1.1.3",
    "mosha-vue-toastify": "^1.0.23",
    "pinia": "^3.0.4",
    "vue": "^3.2.47",
